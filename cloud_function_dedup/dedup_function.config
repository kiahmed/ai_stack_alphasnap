# Function-specific tunables for cloud_function_dedup. Sourced by deploy.sh
# and test_fire.sh. PROJECT_ID / LOCATION / SA_EMAIL are inherited from
# ../ae_config.config — no need to duplicate them here.

FUNCTION_NAME="arboryx-master-log-dedup"
SCHEDULER_JOB="arboryx-master-log-dedup-biweekly"

# 21:00 (9 PM) America/New_York on the 1st and 15th of each month.
# 21:00 ET satisfies the "after 8pm EST" requirement with cushion.
SCHEDULE_CRON="0 21 1,15 * *"
SCHEDULE_TZ="America/New_York"

# GCS — bucket holds the master findings log. Object name + backup prefix
# match the conventions in market_team.py / values.yaml storage.gcs_path.
GCS_BUCKET="marketresearch-agents"
GCS_OBJECT="market_findings_log.json"
BACKUP_PREFIX="backups/"

# Email
GMAIL_FROM="arborix.platform@gmail.com"
GMAIL_TO="arborix.platform@gmail.com"
# App password lives in Secret Manager as 'arboryx-ai-engine-dedup-Gmail-password'.
# (Secret Manager IDs allow only [A-Za-z0-9_-] — no periods, so the project
# name 'arboryx.ai' becomes 'arboryx-ai' here.)
# deploy.sh creates it on first run if missing (prompts for the value).
GMAIL_SECRET_NAME="arboryx-ai-engine-dedup-Gmail-password"

# Dedup thresholds — kept aligned with values.yaml + market_team.py.
TFIDF_THRESHOLD="0.35"
ENTITY_THRESHOLD="0.6"
NOVELTY_MIN="3"
TFIDF_FLOOR_FOR_ENTITY="0.15"
MEMORY_LIMIT="10"

# Retry policy
RETRY_ATTEMPTS="3"
RETRY_DELAY_SEC="5"
