PROJECT_ID="marketresearch-agents"
LOCATION="us-central1"
SA_EMAIL="market-agent-sa@marketresearch-agents.iam.gserviceaccount.com"
ENGINE_ID="3245706098392432640"

# === DEPLOYMENT CONFIGURATION ===
STAGING_BUCKET="gs://marketresearch-agents"
# Semicolon-separated lists for python requirements and extra packages
REQUIREMENTS="google-cloud-aiplatform[agent_engines,adk];google-cloud-storage;pyyaml"
EXTRA_PACKAGES="market_team.py;values.yaml"

# === SCHEDULER CONFIGURATION ===
SCHEDULER_NAME="market-team-daily-sweeper"
SCHEDULE_INTERVAL="15 7 * * *"
TIMEZONE="America/New_York"
# TRIGGER_MODE controls how trigger_scheduler.sh invokes the agent.
#   "api"       → Direct streamQuery call to the Reasoning Engine (default)
#   "scheduler" → Triggers via Cloud Scheduler job
TRIGGER_MODE="scheduler"
