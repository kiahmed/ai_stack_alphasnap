# ── MCP Server Configuration ──
# Swap these values to point at a different MCP server.

# Server endpoint (StreamableHTTP)
MCP_SERVER_URL=""

# OAuth2 client-credentials grant
MCP_OAUTH_TOKEN_URL=""
MCP_OAUTH_CLIENT_ID=""
MCP_OAUTH_CLIENT_SECRET=""

# Auth type: "oauth2" or "bearer" or "none"
# oauth2  = fetch token via client_credentials grant (above)
# bearer  = use MCP_STATIC_TOKEN directly
# none    = no auth header
MCP_AUTH_TYPE="oauth2"

# Static bearer token (used when MCP_AUTH_TYPE="bearer")
MCP_STATIC_TOKEN=""
